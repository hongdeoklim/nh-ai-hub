# ===========================================================================
# .claudeignore — Claude Code 컨텍스트/검색에서 제외할 경로
# 목적: 토큰 낭비 방지 + 민감정보 유출 방지
# ===========================================================================

# --- 의존성 / 빌드 산출물 (가장 큰 토큰 낭비 요인) -------------------------
node_modules/
dist/
dist-ssr/
build/
.firebase/
.vite/
.cache/

# --- 패키지 락 파일 (수십만 줄, 읽을 필요 없음) ----------------------------
package-lock.json
pnpm-lock.yaml
yarn.lock

# --- 로그 --------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
db-output.txt

# --- 민감 정보 / 자격 증명 (절대 컨텍스트에 들어가면 안 됨) ----------------
.env
.env.*
!.env.example
key.txt
*.pem
*.key
# Google 서비스 계정 키 (루트에 노출되어 있음 — 반드시 제외)
nh-ai-hub-*.json

# --- 에디터 / OS ------------------------------------------------------------
.vscode/
.idea/
.DS_Store
*.suo
*.sw?

# --- 작업용 임시 폴더 / 테스트 스크래치 ------------------------------------
scratch/
*.local
test-gemini*.js

# --- 정적 에셋 (대용량 바이너리, 코드 분석 불필요) -------------------------
public/**/*.png
public/**/*.jpg
public/**/*.jpeg
public/**/*.webp
public/**/*.mp4
public/**/*.pdf
src/assets/**/*.png
src/assets/**/*.jpg
src/assets/**/*.webp
