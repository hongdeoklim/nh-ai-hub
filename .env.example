# -----------------------------------------------------------------------------
# NH AI Inside Hub — 환경 변수 예시
# 프로젝트 루트에 `.env` 로 복사한 뒤 값을 채우세요.
# -----------------------------------------------------------------------------

# 로컬 개발 전용 임시 로그인 — Login 화면에 「임시 로그인」 버튼 표시.
# Supabase Auth 에 미리 만든 테스트 계정을 넣으세요. VITE_* 는 번들에 포함되므로 프로덕션·Git 금지.
# VITE_DEV_LOGIN_EMAIL=
# VITE_DEV_LOGIN_PASSWORD=

# --- 프론트(Vite) — Supabase 클라이언트 ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# OAuth 리다이렉트 (브라우저 주소). GCP OAuth 클라이언트 승인 URI와 문자열이 완전히 같아야 합니다.
# 예: 로컬 http://localhost:5173/oauth/google-integration
# VITE_GOOGLE_OAUTH_REDIRECT_URI=

# AI 호출 경로: edge(기본, Functions 사용) | direct(로컬 실험용 — 비권장)
# VITE_AI_TRANSPORT=edge

# Workflows(Nuxt 등 외부 앱) — /workflows 에 iframe으로 표시. 미설정 시 Hub 내 미리보기 UI
# VITE_WORKFLOWS_APP_URL=http://localhost:3000

# direct 모드에서만 필요 — 번들에 키가 포함되므로 프로덕션 금지
# VITE_OPENAI_API_KEY=
# VITE_GOOGLE_GENERATIVE_AI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_NH_AI_GUARDRAIL_PROVIDER=openai

# -----------------------------------------------------------------------------
# 서버 전용 (Supabase Edge Function Secrets — `supabase secrets set`)
# 대시보드 번들에 넣지 마세요.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
NH_AI_GUARDRAIL_PROVIDER=openai

# --- Google Drive (현장 이미지 영구 저장, OAuth 2.0 + Refresh Token) ---
# Drive에서 만든 저장용 폴더 ID (브라우저 주소창 .../folders/<이 값>)
GDRIVE_ROOT_FOLDER_ID=
# Google Cloud Console → APIs & Services → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
# OAuth 동의 화면에서 Drive 스코프로 발급받은 리프레시 토큰(1회 교환 후 보관)
GDRIVE_REFRESH_TOKEN=
#
# 참고:
# - 리프레시 토큰은 GCP/OAuth 클라이언트 타입·테스트 사용자 설정에 따라 만료·폐기될 수 있음
# - 업로드 주체는 이 토큰을 발급받은 Google 계정이므로, 해당 계정이 GDRIVE_ROOT_FOLDER_ID 폴더에
#   적절한 권한(편집자 등)을 갖는지 확인할 것
# - Shared drive 사용 시 폴더/드라이브 공유 설정을 동일하게 맞출 것

# --- 사용자별 Google 연동 (Drive · Sheets · Calendar 스코프, Edge Secrets) ---
# 프론트 VITE_GOOGLE_OAUTH_REDIRECT_URI 와 동일한 문자열을 Edge에도 설정합니다.
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_APP/oauth/google-integration
# 미설정 시 GDRIVE_CLIENT_ID / GDRIVE_CLIENT_SECRET 재사용 가능
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# OAuth state 서명용 임의 긴 문자열(32바이트 이상 권장)
# INTEGRATION_OAUTH_STATE_SECRET=
# 리프레시 토큰 AES-GCM 암호화용 임의 긴 문자열(32바이트 이상 권장)
# INTEGRATION_CREDENTIALS_SECRET=
# 사용자별 credentials 테이블 접근용 — Supabase 대시보드 Project Settings → API 의 service_role
# SUPABASE_SERVICE_ROLE_KEY=
